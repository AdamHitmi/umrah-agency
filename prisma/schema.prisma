generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AdminRole {
  SUPER_ADMIN
  EDITOR
}

enum BookingStatus {
  PENDING
  CONTACTED
  CONFIRMED
  CANCELLED
}

model AdminUser {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String
  role         AdminRole @default(EDITOR)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Package {
  id                 String               @id @default(cuid())
  slug               String               @unique
  titleAr            String
  titleFr            String
  shortDescriptionAr String
  shortDescriptionFr String
  descriptionAr      String
  descriptionFr      String
  startDate          DateTime
  endDate            DateTime
  durationDays       Int
  isDirectFlight     Boolean              @default(false)
  countryAr          String
  countryFr          String
  originCityAr       String
  originCityFr       String
  featured           Boolean              @default(false)
  active             Boolean              @default(true)
  visaIncluded       Boolean              @default(false)
  heroImage          String
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  destinations       PackageDestination[]
  priceGroups        PackagePriceGroup[]
  inclusions         PackageInclusion[]
  notes              PackageNote[]
  hotels             HotelOption[]
  bookingRequests    BookingRequest[]

  @@index([active, featured])
  @@index([startDate])
}

model PackageDestination {
  id          String  @id @default(cuid())
  packageId   String
  nameAr      String
  nameFr      String
  airportCode String?
  sortOrder   Int
  package     Package @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@index([packageId, sortOrder])
}

model PackagePriceGroup {
  id         String             @id @default(cuid())
  packageId  String
  roomTypeAr String
  roomTypeFr String
  sortOrder  Int
  package    Package            @relation(fields: [packageId], references: [id], onDelete: Cascade)
  tiers      PackagePriceTier[]

  @@index([packageId, sortOrder])
}

model PackagePriceTier {
  id           String            @id @default(cuid())
  priceGroupId String
  labelAr      String
  labelFr      String
  amountMad    Int
  sortOrder    Int
  priceGroup   PackagePriceGroup @relation(fields: [priceGroupId], references: [id], onDelete: Cascade)

  @@index([priceGroupId, sortOrder])
}

model PackageInclusion {
  id        String  @id @default(cuid())
  packageId String
  textAr    String
  textFr    String
  sortOrder Int
  package   Package @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@index([packageId, sortOrder])
}

model PackageNote {
  id        String  @id @default(cuid())
  packageId String
  textAr    String
  textFr    String
  sortOrder Int
  package   Package @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@index([packageId, sortOrder])
}

model HotelOption {
  id           String  @id @default(cuid())
  packageId    String
  name         String
  city         String
  stars        Int
  descriptionAr String
  descriptionFr String
  sortOrder    Int
  package      Package @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@index([packageId, sortOrder])
}

model BookingRequest {
  id             String        @id @default(cuid())
  packageId       String
  fullName       String
  phone          String
  email          String
  city           String
  roomType       String
  travelersCount Int
  notes          String?
  status         BookingStatus @default(PENDING)
  createdAt      DateTime      @default(now())
  package        Package       @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@index([packageId, createdAt])
  @@index([status])
}

model ContactSubmission {
  id        String   @id @default(cuid())
  fullName  String
  phone     String
  email     String
  subject   String
  message   String
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model FAQ {
  id         String  @id @default(cuid())
  questionAr String
  questionFr String
  answerAr   String
  answerFr   String
  sortOrder  Int     @default(0)
  active     Boolean @default(true)

  @@index([active, sortOrder])
}

model Testimonial {
  id        String  @id @default(cuid())
  name      String
  city      String
  rating    Int
  contentAr String
  contentFr String
  active    Boolean @default(true)
  sortOrder Int     @default(0)

  @@index([active, sortOrder])
}

model SiteSetting {
  id               String @id @default(cuid())
  agencyNameAr     String
  agencyNameFr     String
  email            String @default("")
  phone            String
  whatsapp         String
  cityAr           String
  cityFr           String
  addressAr        String
  addressFr        String
  officeHoursAr    String
  officeHoursFr    String
  facebookUrl      String?
  instagramUrl     String?
  tiktokUrl        String?
  heroTitleAr      String
  heroTitleFr      String
  heroSubtitleAr   String
  heroSubtitleFr   String
  aboutIntroAr     String
  aboutIntroFr     String
  promiseAr        String
  promiseFr        String
  whyChooseTitleAr String
  whyChooseTitleFr String
  whyChooseTextAr  String
  whyChooseTextFr  String
}
